{
  "agentName": "azdo-reader-v2",
  "version": "1.0.0",
  "type": "generic-prompt-agent",
  "baseAgentVersion": "0.54.0",
  "maintainer": "FAB Agents Team",
  
  "design": {
    "systemMessage": "You are an Azure DevOps bug reader agent with access to Azure DevOps REST APIs and Git repositories.\n\nYour job:\n1. Read work items (bugs) from Azure DevOps\n2. Validate content and extract key information\n3. Analyze code impact by reading repository files\n4. Return structured JSON responses\n\nKey Responsibilities:\n- Authenticate using PAT token\n- Query work items by ID\n- Extract fields: ID, Title, Description, State, Tags, Priority, Comments, Assignee\n- Read repository structure and affected files\n- Analyze code changes needed\n- Return all data in structured JSON format\n\nWhen responding, always include status codes and detailed information.",
    
    "userPromptTemplate": "[query]",
    
    "openAPIEndpoint": "https://raw.githubusercontent.com/tushar270721/CodeGameRepo/main/apis/azdo-openapi-spec.yaml",
    
    "headers": {
      "Authorization": "Basic {{AZURE_DEVOPS_PAT_BASE64}}",
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    
    "openAPISpecHeaders": {
      "Authorization": "Basic {{AZURE_DEVOPS_PAT_BASE64}}",
      "Accept": "application/yaml"
    },
    
    "allowedHttpMethods": ["GET", "POST", "PUT", "PATCH", "DELETE"],
    
    "delegateToOtherAgents": false,
    "useExternalAPIs": true
  },
  
  "configuration": {
    "timeout": 30000,
    "retryAttempts": 3,
    "cacheResults": true,
    "cacheDuration": 300
  },
  
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "The query or command to execute"
      },
      "workItemId": {
        "type": "string",
        "description": "Azure DevOps work item ID (optional)"
      },
      "organization": {
        "type": "string",
        "description": "Azure DevOps organization name (optional)"
      },
      "project": {
        "type": "string",
        "description": "Azure DevOps project name (optional)"
      }
    }
  },
  
  "outputSchema": {
    "type": "object",
    "properties": {
      "statusCode": {
        "type": "integer",
        "description": "HTTP status code"
      },
      "reason": {
        "type": "string",
        "description": "Reason for the response"
      },
      "message": {
        "type": "string",
        "description": "Response message"
      },
      "error": {
        "type": "string",
        "description": "Error message if any"
      },
      "details": {
        "type": "object",
        "description": "Detailed response data"
      }
    }
  },
  
  "testInputs": [
    {
      "name": "Read Bug Details",
      "input": {
        "query": "Get details for bug ID 791842 from Azure DevOps organization"
      }
    },
    {
      "name": "Search Agent-Ready Bugs",
      "input": {
        "query": "Find all work items tagged with 'agent-ready' that are in Active state"
      }
    },
    {
      "name": "List Repositories",
      "input": {
        "query": "List all Git repositories in the project"
      }
    }
  ],
  
  "capabilities": [
    "Read work items from Azure DevOps",
    "Search work items using WIQL queries",
    "List Git repositories",
    "Get commit history",
    "Create pull requests",
    "Access build information",
    "Extract work item details and metadata"
  ]
}
